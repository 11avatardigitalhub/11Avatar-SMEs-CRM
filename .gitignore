# ============================================================
# 11 AVATAR SMEs CRM — GIT IGNORE FILE
# ============================================================
# Prevents sensitive, generated, and unnecessary files
# from being committed to the repository.
# ============================================================

# ============================================================
# DEPENDENCIES
# ============================================================
node_modules/
bower_components/
jspm_packages/

# ============================================================
# BUILD OUTPUT
# ============================================================
dist/
build/
out/
.next/
.nuxt/
.cache/
parcel-cache/

