config/secrets.js
config/credentials.json
config/serviceAccountKey.json
firebase-service-account.json
*.pem
*.key
*.crt
*.csr

# ============================================================
# UPLOADS & USER CONTENT
# ============================================================
uploads/
user-uploads/
temp-uploads/
*.upload

# ============================================================
# COVERAGE & TESTING
# ============================================================
coverage/
.nyc_output/
.jest/
cypress/
test-results/
reports/

# ============================================================
# DOCS GENERATED
# ============================================================
docs/_build/
docs/.doctrees/
site/

# ============================================================
# DATABASE & BACKUPS
# ============================================================
*.sql
*.sqlite
*.sqlite3
*.db
dump/
backups/
*.backup

# ============================================================
