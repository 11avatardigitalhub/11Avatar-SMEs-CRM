*.js.map
*.ts.map

# ============================================================
# DOCKER
# ============================================================
.docker/
docker-compose.override.yml

# ============================================================
# KEEP THESE FILES (Negations)
# ============================================================
# Keep important dotfiles
!.gitignore
!.gitattributes
!.editorconfig
!.prettierrc
!.eslintrc.json
!.stylelintrc.json

# Keep example env files
!.env.example
!.env.sample

.dev.vars*
!.dev.vars.example
